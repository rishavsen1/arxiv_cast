# Open Router API key (get one at https://openrouter.ai)
# Copy this file to .env and fill in your key. Never commit .env.
OPENROUTER_KEY=sk-or-v1-your-key-here

# Optional: TTS engine for podcast voices. "edge" = free Edge TTS (default). "openai" = ChatGPT-style natural voices.
# TTS_ENGINE=openai
# OPENAI_API_KEY=sk-your-openai-key

# Optional: OpenAI TTS voice names (Alex / Sam). Defaults: cedar (male), nova (female). Model: tts-1-hd or gpt-4o-mini-tts.
# OPENAI_TTS_VOICE_ALEX=cedar
# OPENAI_TTS_VOICE_SAM=nova
# OPENAI_TTS_MODEL=tts-1-hd

# —— Voice chat (free, local) ——
# STT: faster-whisper (default). Model: small.en, base.en, tiny.en.
# VOICE_STT_PROVIDER=faster_whisper
# VOICE_STT_MODEL=small.en
# VOICE_STT_DEVICE=cpu
# VOICE_STT_COMPUTE_TYPE=int8

# LLM: ollama (default, no key), or openrouter / nvidia_nim.
# VOICE_LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# OpenRouter fallback (optional)
# VOICE_LLM_PROVIDER=openrouter
# OPENROUTER_MODEL=openai/gpt-3.5-turbo

# NVIDIA NIM fallback (optional)
# VOICE_LLM_PROVIDER=nvidia_nim
# NIM_CHAT_URL=https://...
# NIM_API_KEY=

# TTS: Piper (default). Put .onnx voice in arxvicast/voices/ or set path.
# VOICE_TTS_PROVIDER=piper
# PIPER_VOICE_PATH=/path/to/en_US-lessac-medium.onnx

# Timeouts (seconds)
# VOICE_STT_TIMEOUT=10
# VOICE_LLM_TIMEOUT=30
# VOICE_TTS_TIMEOUT=15
