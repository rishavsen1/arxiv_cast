# Open Router API key (get one at https://openrouter.ai)
# Copy this file to .env and fill in your key. Never commit .env.
OPENROUTER_KEY=sk-or-v1-your-key-here

# Optional: TTS engine for podcast voices. "edge" = free Edge TTS (default). "openai" = ChatGPT-style natural voices.
# TTS_ENGINE=openai
# OPENAI_API_KEY=sk-your-openai-key

# Optional: OpenAI TTS voice names (Alex / Sam). Defaults: cedar (male), nova (female). Model: tts-1-hd or gpt-4o-mini-tts.
# OPENAI_TTS_VOICE_ALEX=cedar
# OPENAI_TTS_VOICE_SAM=nova
# OPENAI_TTS_MODEL=tts-1-hd
